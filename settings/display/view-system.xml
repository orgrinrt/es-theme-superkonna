<!--
  Theme: Superkonna
  System carousel: full-screen art, floating logos, minimal chrome.
  Screen view: frosted glass top bar.
-->

<theme>
  <formatVersion>7</formatVersion>

  <!-- ════════════════════════════════════════════════════════════
       SYSTEM VIEW: Immersive carousel
       Full-screen system art with logos floating over it.
       Subtle gradient for depth, cascading info on selection.
       ════════════════════════════════════════════════════════════ -->
  <view name="system">

    <!-- Default background gradient — shown when no system art exists -->
    <image name="cover_fallback" extra="true">
      <size>1 1</size>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <color>182235</color>
      <zIndex>-10</zIndex>
    </image>

    <!-- Background art — fills entire screen, slow crossfade -->
    <image name="cover" extra="true">
      <path>./assets/systems/${system.theme}.jpg</path>
      <path>./assets/systems/${system.theme}.webp</path>
      <path>./assets/systems/${system.theme}.png</path>
      <path>./assets/systems/${system.theme}.svg</path>
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <zIndex>-9</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" begin="0" duration="1000" mode="easeOut"/>
        <animation property="scale" from="1.03" to="1" begin="0" duration="1200" mode="easeOut"/>
      </storyboard>
    </image>

    <!-- Darken overlay — from scheme.xml system view section -->
    <image name="background_overlay" extra="true">
      <size>1 1</size>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <zIndex>-7</zIndex>
    </image>

    <!-- Bottom vignette — soft gradient for depth -->
    <image name="system_bottom_fade" extra="true">
      <path>./assets/fade-ver.png</path>
      <origin>0 1</origin>
      <pos>0 1</pos>
      <size>1 0.4</size>
      <color>0A0D12</color>
      <rotation>180</rotation>
      <zIndex>-6</zIndex>
    </image>

    <!-- ── Carousel ──────────────────────────────────────────── -->
    <carousel name="systemcarousel">
      <type>horizontal</type>
      <pos>-0.660 -0.10</pos>
      <size>1.76 1</size>
      <logoScale>1.15</logoScale>
      <logoSize>0.19 0.21</logoSize>
      <color>FFFFFF15</color>
      <selectedColor>FFFFFF30</selectedColor>
      <maxLogoCount>9</maxLogoCount>
      <zIndex>42</zIndex>
      <logoAlignment>bottom</logoAlignment>
      <defaultTransition>slide</defaultTransition>
      <systemInfoDelay>200</systemInfoDelay>
      <minLogoOpacity>0.25</minLogoOpacity>
      <imageSource>thumbnail</imageSource>
      <scrollSound>./assets/sounds/scroll.wav</scrollSound>
    </carousel>

    <!-- System name — subtle, bottom-left, cascading reveal -->
    <text name="systemName" extra="true">
      <text>${system.fullName}</text>
      <origin>0 1</origin>
      <pos>0.05 0.88</pos>
      <size>0.5 ${fontSizeH2-medium}</size>
      <fontPath>${fontDisplay}</fontPath>
      <forceUppercase>1</forceUppercase>
      <lineSpacing>1</lineSpacing>
      <alignment>left</alignment>
      <color>EAEDF3</color>
      <glowColor>0A0D12E6</glowColor>
      <glowSize>4</glowSize>
      <zIndex>50</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="150" mode="linear"/>
        <animation property="opacity" from="0" to="1" begin="200" duration="300" mode="easeOut"/>
        <animation property="y" from="0.90" to="0.88" begin="200" duration="350" mode="easeOut"/>
      </storyboard>
    </text>

    <!-- Game count — small, below system name -->
    <text name="systemInfo">
      <origin>0 1</origin>
      <pos>0.05 0.925</pos>
      <size>0.3 ${fontSizeCaption-medium}</size>
      <alignment>left</alignment>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1.3</lineSpacing>
      <color>EAEDF366</color>
      <glowColor>0A0D12CC</glowColor>
      <glowSize>2</glowSize>
      <zIndex>50</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="200" mode="linear"/>
        <animation property="opacity" from="0" to="0.7" begin="300" duration="250" mode="easeOut"/>
        <animation property="y" from="0.94" to="0.925" begin="300" duration="300" mode="easeOut"/>
      </storyboard>
    </text>

    <!-- Manufacturer — hide (redundant with background art) -->
    <text name="systemManufacturer" extra="true">
      <visible>false</visible>
    </text>

    <!-- logoText fallback — shown when no logo SVG exists -->
    <text name="logoText">
      <origin>0.5 0.5</origin>
      <fontPath>${fontDisplay}</fontPath>
      <fontSize>${fontSizeH3-medium}</fontSize>
      <forceUppercase>1</forceUppercase>
      <alignment>center</alignment>
      <color>EAEDF3</color>
      <glowColor>0A0D12CC</glowColor>
      <glowSize>3</glowSize>
    </text>

    <!-- System logo (SVG preferred) -->
    <image name="logo">
      <path>./assets/logos/${system.theme}.svg</path>
      <path>./assets/logos/${system.theme}.png</path>
      <path>./assets/logos/${system.theme}.jpg</path>
    </image>

  </view>

  <!-- OSD background (all game views) -->
  <view name="system, basic, detailed, grid">
    <image name="osdBackground" extra="true">
      <pos>0 0</pos>
      <origin>0 0</origin>
      <size>1 1</size>
      <zIndex>100</zIndex>
    </image>
  </view>

  <!-- ════════════════════════════════════════════════════════════
       SCREEN VIEW: Floating frosted glass top bar
       Persistent across all views.
       ════════════════════════════════════════════════════════════ -->
  <view name="screen">

    <!-- Top bar background: frosted glass pill -->
    <image name="topbar_bg" extra="true">
      <pos>0.015 0.012</pos>
      <origin>0 0</origin>
      <size>0.97 0.055</size>
      <roundCorners>0.012</roundCorners>
      <zIndex>9</zIndex>
    </image>

    <!-- Controller activity dots -->
    <controllerActivity name="controllerActivity">
      <origin>0 0.5</origin>
      <pos>0.04 0.039</pos>
      <size>0.012</size>
      <itemSpacing>0.004</itemSpacing>
      <imagePath>./assets/pin.svg</imagePath>
    </controllerActivity>

    <!-- RetroAchievements user -->
    <text name="ra_user" extra="true" ifCheevos="true">
      <text>{global:cheevosUser}</text>
      <origin>0 0.5</origin>
      <pos>0.10 0.039</pos>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1</lineSpacing>
      <zIndex>11</zIndex>
    </text>

    <!-- Clock: right side -->
    <text name="clock">
      <origin>1 0.5</origin>
      <pos>0.97 0.039</pos>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1</lineSpacing>
      <alignment>right</alignment>
    </text>

    <!-- Battery indicator -->
    <batteryIndicator name="batteryIndicator">
      <origin>1 0.5</origin>
      <pos>0.92 0.039</pos>
      <size>0.016</size>
    </batteryIndicator>

  </view>
</theme>
