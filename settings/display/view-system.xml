<!--
  Theme: Superkonna
  System view: full-screen art background + itemTemplate carousel
  See DESIGN.md for layer architecture and design rationale.
-->

<theme>
  <formatVersion>7</formatVersion>

  <view name="system">

    <!-- ══════════════════════════════════════════════════════════
         BACKGROUND: Full-screen system art + overlays
         ══════════════════════════════════════════════════════════ -->

    <!-- Background layers (deepest to shallowest):
         -10: fallback gradient (always renders, covers empty state)
         -9:  random game screenshot (for systems with scraped media)
         -8:  system-specific art (highest priority, covers everything below) -->

    <image name="bg_fallback" extra="true">
      <path>./assets/fallback-bg.png</path>
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <linearSmooth>true</linearSmooth>
      <zIndex>-10</zIndex>
    </image>

    <image name="bg_random" extra="true">
      <path>{random:fanart}</path>
      <path>{random:image}</path>
      <path>{random:thumbnail}</path>
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <linearSmooth>true</linearSmooth>
      <zIndex>-9</zIndex>
    </image>

    <image name="cover" extra="true">
      <path>./assets/systems/${system.theme}.webp</path>
      <path>./assets/systems/${system.theme}.jpg</path>
      <path>./assets/systems/${system.theme}.png</path>
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <linearSmooth>true</linearSmooth>
      <zIndex>-8</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" duration="${animCrossfade}" mode="EaseOut"/>
      </storyboard>
    </image>

    <!-- Dark overlay for contrast -->
    <image name="bg_overlay" extra="true">
      <path>./assets/card-bg.png</path>
      <size>1 1</size>
      <color>${shadowColor}${percent.40}</color>
      <zIndex>-7</zIndex>
    </image>

    <!-- Bottom vignette -->
    <image name="bg_vignette" extra="true">
      <path>./assets/fade-ver.png</path>
      <origin>0 1</origin>
      <pos>0 1</pos>
      <size>1 0.45</size>
      <color>${shadowColor}${percent.90}</color>
      <rotation>180</rotation>
      <zIndex>-6</zIndex>
    </image>

    <!-- ══════════════════════════════════════════════════════════
         CAROUSEL: Composited card stack via itemTemplate
         ══════════════════════════════════════════════════════════ -->

    <carousel name="systemcarousel">
      <type>horizontal</type>
      <pos>${carouselXOffset} ${carouselY}</pos>
      <size>${carouselWidth} ${carouselH}</size>
      <color>00000000</color>
      <logoSize>${cardLogoSize}</logoSize>
      <logoScale>${cardLogoScale}</logoScale>
      <maxLogoCount>${cardMaxVisible}</maxLogoCount>
      <logoAlignment>center</logoAlignment>
      <defaultTransition>slide</defaultTransition>
      <transitionSpeed>350</transitionSpeed>
      <minLogoOpacity>${minCardOpacity}</minLogoOpacity>
      <linearSmooth>true</linearSmooth>
      <scrollSound>./assets/sounds/scroll.wav</scrollSound>
      <systemInfoDelay>0</systemInfoDelay>

      <itemTemplate>
        <!-- Layer 1: Opaque card base (per-system color PNG) -->
        <image name="cardBg" extra="true">
          <path>./assets/cards/${system.theme}.png</path>
          <path>./assets/cards/_default.png</path>
          <pos>0.5 0.5</pos>
          <origin>0.5 0.5</origin>
          <size>1 1</size>
          <roundCorners>${cardCornerRadius}</roundCorners>
          <zIndex>1</zIndex>
        </image>

        <!-- Layer 2: Gradient overlay (depth) -->
        <image name="cardGradient" extra="true">
          <path>./assets/card-gradient.png</path>
          <pos>0.5 0.5</pos>
          <origin>0.5 0.5</origin>
          <size>1 1</size>
          <opacity>${gradientOverlayOpacity}</opacity>
          <roundCorners>${cardCornerRadius}</roundCorners>
          <zIndex>2</zIndex>
        </image>

        <!-- Layer 3: Glint sweep (on activate only) -->
        <image name="cardGlint" extra="true">
          <path>./assets/glint.png</path>
          <pos>0.5 0.5</pos>
          <origin>0.5 0.5</origin>
          <size>1 1</size>
          <opacity>0</opacity>
          <roundCorners>${cardCornerRadius}</roundCorners>
          <zIndex>3</zIndex>
          <storyboard event="activate">
            <animation property="x" from="0" to="1.0" duration="400" mode="EaseOut"/>
            <animation property="opacity" from="0" to="${glintPeakOpacity}" duration="100" mode="EaseOut"/>
            <animation property="opacity" from="${glintPeakOpacity}" to="0" begin="250" duration="150" mode="EaseIn"/>
          </storyboard>
          <storyboard event="deactivate">
            <animation property="opacity" to="0" duration="0"/>
          </storyboard>
        </image>

        <!-- Layer 4: System logo -->
        <image name="theLogo">
          <path>{system:image}</path>
          <pos>0.5 ${cardLogoY}</pos>
          <origin>0.5 0.5</origin>
          <maxSize>${cardLogoMaxSize}</maxSize>
          <linearSmooth>true</linearSmooth>
          <zIndex>5</zIndex>
        </image>
      </itemTemplate>
    </carousel>

    <!-- Logo path resolution (ES uses this for {system:image}) -->
    <image name="logo">
      <path>./assets/logos/${system.theme}.svg</path>
      <path>./assets/logos/${system.theme}.png</path>
    </image>

    <!-- logoText fallback -->
    <text name="logoText">
      <fontPath>${fontDisplay}</fontPath>
      <fontSize>${fontSizeH3}</fontSize>
      <forceUppercase>1</forceUppercase>
      <alignment>center</alignment>
      <color>EAEDF3</color>
    </text>

    <!-- Hide all text -->
    <text name="systemName" extra="true">
      <visible>false</visible>
    </text>

    <text name="systemInfo">
      <visible>false</visible>
    </text>

    <text name="systemManufacturer" extra="true">
      <visible>false</visible>
    </text>

  </view>

  <!-- ══════════════════════════════════════════════════════════
       SCREEN VIEW: Top bar
       ══════════════════════════════════════════════════════════ -->

  <view name="screen">
    <image name="topbar_bg" extra="true">
      <path>./assets/card-bg.png</path>
      <pos>0.015 0.012</pos>
      <origin>0 0</origin>
      <size>0.97 0.055</size>
      <roundCorners>8</roundCorners>
      <zIndex>9</zIndex>
    </image>

    <controllerActivity name="controllerActivity">
      <origin>0 0.5</origin>
      <pos>0.04 0.039</pos>
      <size>0.012</size>
      <itemSpacing>0.004</itemSpacing>
      <imagePath>./assets/pin.svg</imagePath>
    </controllerActivity>

    <text name="clock">
      <origin>1 0.5</origin>
      <pos>0.97 0.039</pos>
      <fontSize>${fontSizeCaption}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1</lineSpacing>
      <alignment>right</alignment>
    </text>

    <batteryIndicator name="batteryIndicator">
      <origin>1 0.5</origin>
      <pos>0.92 0.039</pos>
      <size>0.016</size>
    </batteryIndicator>

    <!-- Help system: hidden, replaced by custom hint strips -->
    <helpsystem name="help">
      <textColor>00000000</textColor>
      <iconColor>00000000</iconColor>
    </helpsystem>

    <!-- Custom hint strips (generated by scripts/update-hints.sh) -->
    <image name="hint_left" extra="true">
      <path>./generated/hints-system-left.svg</path>
      <origin>0 1</origin>
      <pos>0.02 0.97</pos>
      <maxSize>0.30 0.025</maxSize>
      <opacity>0.6</opacity>
      <zIndex>20</zIndex>
    </image>

    <image name="hint_right" extra="true">
      <path>./generated/hints-system-right.svg</path>
      <origin>1 1</origin>
      <pos>0.98 0.97</pos>
      <maxSize>0.30 0.025</maxSize>
      <opacity>0.6</opacity>
      <zIndex>20</zIndex>
    </image>
  </view>

</theme>
