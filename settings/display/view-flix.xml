<!--
  Theme: Superkonna — Flix view
  Netflix-inspired game browser: full-screen fanart, gradient, cover rail, metadata.
  Inherits grid view. See DESIGN.md for architecture.
-->
<theme>
  <formatVersion>7</formatVersion>

  <customView name="flix" inherits="grid">

    <!-- ═══════════════════════════════════════════════════════════
         BACKGROUND: Selected game fanart + video
         Uses md_image for fanart (full-screen), falls back gracefully.
         ═══════════════════════════════════════════════════════════ -->

    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <linearSmooth>true</linearSmooth>
      <zIndex>-2</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" duration="600" mode="EaseOut"/>
        <animation property="scale" from="1.02" to="1" duration="800" mode="EaseOut"/>
      </storyboard>
    </image>

    <video name="md_video">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <zIndex>-1</zIndex>
      <delay>2</delay>
      <showSnapshotNoVideo>false</showSnapshotNoVideo>
      <showSnapshotDelay>false</showSnapshotDelay>
      <effect>none</effect>
      <storyboard>
        <animation property="opacity" from="0" to="1" duration="800" mode="EaseOut"/>
      </storyboard>
    </video>

    <!-- ═══════════════════════════════════════════════════════════
         OVERLAYS: Gradients for readability
         ═══════════════════════════════════════════════════════════ -->

    <!-- Bottom gradient — light, console-style -->
    <image name="flix_gradient" extra="true">
      <path>./assets/fade-ver.png</path>
      <origin>0 1</origin>
      <pos>0 1</pos>
      <size>1 0.65</size>
      <color>${bgColor}</color>
      <rotation>180</rotation>
      <zIndex>1</zIndex>
    </image>

    <!-- Top vignette — subtle dark for logo contrast -->
    <image name="flix_top_fade" extra="true">
      <path>./assets/fade-ver.png</path>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <size>1 0.15</size>
      <color>${fgColor}${percent.30}</color>
      <zIndex>1</zIndex>
    </image>

    <!-- ═══════════════════════════════════════════════════════════
         SYSTEM LOGO: Small, top-left corner, subtle
         ═══════════════════════════════════════════════════════════ -->

    <image name="logo">
      <pos>0.03 0.03</pos>
      <origin>0 0</origin>
      <maxSize>0.10 0.04</maxSize>
      <opacity>0.5</opacity>
      <linearSmooth>true</linearSmooth>
      <zIndex>6</zIndex>
    </image>

    <!-- Game marquee/logo — below system logo -->
    <image name="md_marquee">
      <pos>0.05 0.08</pos>
      <origin>0 0</origin>
      <maxSize>0.28 0.10</maxSize>
      <linearSmooth>true</linearSmooth>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="80" mode="Linear"/>
        <animation property="opacity" from="0" to="1" begin="200" duration="300" mode="EaseOut"/>
        <animation property="y" from="0.10" to="0.08" begin="200" duration="350" mode="EaseOut"/>
      </storyboard>
    </image>

    <!-- ═══════════════════════════════════════════════════════════
         COVER RAIL: Vertical CD-box style cards at bottom
         ═══════════════════════════════════════════════════════════ -->

    <imagegrid name="gamegrid">
      <pos>0.02 0.68</pos>
      <size>0.96 0.28</size>
      <imageSource>thumbnail</imageSource>
      <scrollDirection>horizontal</scrollDirection>
      <autoLayout>8 1</autoLayout>
      <cellProportion>0.7</cellProportion>
      <animateSelection>true</animateSelection>
      <autoLayoutSelectedZoom>1.08</autoLayoutSelectedZoom>
      <padding>0.005 0.006</padding>
      <margin>0.003 0.005</margin>
      <scrollLoop>true</scrollLoop>
      <linearSmooth>true</linearSmooth>
      <zIndex>5</zIndex>
      <scrollSound>./assets/sounds/tick.wav</scrollSound>
    </imagegrid>

    <gridtile name="default, selected">
      <selectionMode>image</selectionMode>
      <imageSizeMode>minSize</imageSizeMode>
    </gridtile>

    <gridtile name="default">
      <imageColor>FFFFFFCC</imageColor>
      <backgroundColor>00000000</backgroundColor>
      <backgroundCornerSize>0.008</backgroundCornerSize>
    </gridtile>

    <gridtile name="selected">
      <imageColor>FFFFFFFF</imageColor>
      <backgroundColor>${cardColor}${percent.10}</backgroundColor>
      <backgroundCornerSize>0.008</backgroundCornerSize>
    </gridtile>

    <image name="gridtile.image">
      <roundCorners>0.008</roundCorners>
    </image>

    <image name="gridtile.image:selected">
      <roundCorners>0.008</roundCorners>
      <saturation>1.1</saturation>
    </image>

    <text name="gridtile">
      <visible>false</visible>
    </text>

    <image name="gridtile.marquee">
      <color>00000000</color>
    </image>

    <!-- ═══════════════════════════════════════════════════════════
         METADATA: Cascading fade-in text overlays
         ═══════════════════════════════════════════════════════════ -->

    <text name="md_name">
      <visible>true</visible>
      <pos>0.05 0.42</pos>
      <size>0.55 0.07</size>
      <fontSize>${fontSizeH1}</fontSize>
      <fontPath>${fontDisplay}</fontPath>
      <forceUppercase>0</forceUppercase>
      <color>${fgColor}</color>
      <glowColor>${bgColor}${percent.80}</glowColor>
      <glowSize>3</glowSize>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="80" mode="Linear"/>
        <animation property="opacity" from="0" to="1" begin="100" duration="${animMedium}" mode="EaseOut"/>
        <animation property="y" from="0.44" to="0.42" begin="100" duration="300" mode="EaseOut"/>
      </storyboard>
    </text>

    <text name="md_genre">
      <visible>true</visible>
      <pos>0.05 0.51</pos>
      <size>0.4 0.025</size>
      <fontSize>${fontSizeCaption}</fontSize>
      <fontPath>${fontBody}</fontPath>
      <forceUppercase>1</forceUppercase>
      <color>${fgColor}${percent.50}</color>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="120" mode="Linear"/>
        <animation property="opacity" from="0" to="0.7" begin="200" duration="${animMedium}" mode="EaseOut"/>
      </storyboard>
    </text>

    <text name="md_description">
      <visible>true</visible>
      <pos>0.05 0.55</pos>
      <size>0.50 0.10</size>
      <fontSize>${fontSizeCaption}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1.4</lineSpacing>
      <color>${fgColor}${percent.40}</color>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="150" mode="Linear"/>
        <animation property="opacity" from="0" to="0.8" begin="300" duration="300" mode="EaseOut"/>
      </storyboard>
    </text>

    <text name="md_developer">
      <visible>true</visible>
      <pos>0.05 0.505</pos>
      <size>0.3 0.025</size>
      <fontSize>${fontSizeCaption}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <alignment>left</alignment>
      <color>${fgColor}${percent.30}</color>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="200" mode="Linear"/>
        <animation property="opacity" from="0" to="0.6" begin="350" duration="${animMedium}" mode="EaseOut"/>
      </storyboard>
    </text>

    <rating name="md_rating">
      <visible>true</visible>
      <origin>0 0.5</origin>
      <pos>0.05 0.495</pos>
      <size>0.06 0.015</size>
      <color>${mainColor}</color>
      <unfilledColor>${fgColor}${percent.10}</unfilledColor>
      <zIndex>6</zIndex>
    </rating>

    <!-- Hide everything else -->
    <text name="logoText">
      <visible>false</visible>
    </text>

    <text name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount, md_releasedate, md_publisher, md_players, md_lastplayed, md_playcount">
      <visible>false</visible>
    </text>

    <datetime name="md_releasedate, md_lastplayed">
      <visible>false</visible>
    </datetime>

    <!-- Custom hint strips (generated by scripts/update-hints.sh) -->
    <image name="hint_left" extra="true">
      <path>./generated/hints-gamelist-left.svg</path>
      <origin>0 1</origin>
      <pos>0.02 0.97</pos>
      <maxSize>0.30 0.025</maxSize>
      <opacity>0.5</opacity>
      <zIndex>20</zIndex>
    </image>

    <image name="hint_right" extra="true">
      <path>./generated/hints-gamelist-right.svg</path>
      <origin>1 1</origin>
      <pos>0.98 0.97</pos>
      <maxSize>0.30 0.025</maxSize>
      <opacity>0.5</opacity>
      <zIndex>20</zIndex>
    </image>

  </customView>
</theme>
