<!--
  Theme: Superkonna — Flix view
  Netflix-style: hero preview top, horizontal cover strip bottom
  Built up from tested minimal base.
-->
<theme>
  <formatVersion>7</formatVersion>

  <customView name="flix" inherits="grid">

    <!-- === GAME GRID: Forced 1-row horizontal strip === -->
    <imagegrid name="gamegrid">
      <pos>0 0.50</pos>
      <size>1 0.475</size>
      <size ifHelpPrompts="true">1 0.44</size>
      <imageSource>thumbnail</imageSource>
      <scrollDirection>horizontal</scrollDirection>
      <autoLayout>7 1</autoLayout>
      <animateSelection>true</animateSelection>
      <autoLayoutSelectedZoom>1.06</autoLayoutSelectedZoom>
      <scrollLoop>true</scrollLoop>
      <zIndex>5</zIndex>
      <scrollSound>./assets/sounds/tick.wav</scrollSound>
    </imagegrid>

    <gridtile name="default, selected">
      <selectionMode>image</selectionMode>
      <imageSizeMode>minSize</imageSizeMode>
    </gridtile>

    <gridtile name="default">
      <imageColor>FFFFFFCC</imageColor>
      <backgroundColor>00000000</backgroundColor>
      <backgroundCornerSize>0.02</backgroundCornerSize>
    </gridtile>

    <gridtile name="selected">
      <imageColor>FFFFFFFF</imageColor>
      <backgroundColor>00000000</backgroundColor>
      <backgroundCornerSize>0.02</backgroundCornerSize>
    </gridtile>

    <image name="gridtile.image">
      <roundCorners>0.02</roundCorners>
    </image>

    <image name="gridtile.image:selected">
      <roundCorners>0.02</roundCorners>
    </image>

    <image name="gridtile.favorite">
      <path>./assets/icons/favorite.png</path>
      <pos>0 0</pos>
      <maxSize>0.25 0.25</maxSize>
      <origin>0 0</origin>
    </image>

    <text name="gridtile">
      <size>1 0.2</size>
      <pos>0 0.78</pos>
      <fontPath>${fontBody}</fontPath>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <alignment>center</alignment>
      <lineSpacing>1.2</lineSpacing>
      <color>EAEDF3B3</color>
    </text>

    <text name="gridtile:selected">
      <color>EAEDF3</color>
    </text>

    <image name="gridtile.marquee">
      <color>00000000</color>
    </image>

    <!-- === HERO PREVIEW: Selected game screenshot fills top half === -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.25</pos>
      <size>1 0.5</size>
      <zIndex>-1</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" begin="0" duration="400" mode="easeOut"/>
      </storyboard>
    </image>

    <video name="md_video">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.25</pos>
      <size>1 0.5</size>
      <zIndex>0</zIndex>
      <delay>1</delay>
      <showSnapshotNoVideo>false</showSnapshotNoVideo>
      <showSnapshotDelay>false</showSnapshotDelay>
      <effect>none</effect>
    </video>

    <!-- Game marquee/logo over hero -->
    <image name="md_marquee">
      <pos>0.05 0.05</pos>
      <origin>0 0</origin>
      <maxSize>0.35 0.15</maxSize>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="60" mode="linear"/>
        <animation property="opacity" from="0" to="1" begin="120" duration="200" mode="easeOut"/>
      </storyboard>
    </image>

    <!-- Game description over hero -->
    <text name="md_description">
      <visible>true</visible>
      <pos>0.05 0.25</pos>
      <size>0.4 0.18</size>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1.4</lineSpacing>
      <color>EAEDF3</color>
      <glowColor>000000CC</glowColor>
      <glowSize>3</glowSize>
      <zIndex>5</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="60" mode="linear"/>
        <animation property="opacity" from="0" to="0.85" begin="180" duration="220" mode="easeOut"/>
      </storyboard>
    </text>

    <!-- Genre -->
    <text name="md_genre">
      <visible>true</visible>
      <pos>0.05 0.22</pos>
      <size>0.38 ${fontSizeCaption-medium}</size>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <color>EAEDF3</color>
      <glowColor>000000CC</glowColor>
      <glowSize>2</glowSize>
      <zIndex>5</zIndex>
    </text>

    <!-- System name above grid -->
    <text name="logoText">
      <origin>0 0.5</origin>
      <pos>0.05 0.46</pos>
      <size>0.4 ${fontSizeH3-medium}</size>
      <fontSize>${fontSizeH3-medium}</fontSize>
      <color>EAEDF3</color>
    </text>

    <!-- Hide metadata labels -->
    <text name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount, md_releasedate, md_developer, md_publisher, md_players, md_lastplayed, md_playcount, md_name">
      <visible>false</visible>
    </text>

    <datetime name="md_releasedate, md_lastplayed">
      <visible>false</visible>
    </datetime>

    <rating name="md_rating">
      <visible>false</visible>
    </rating>

  </customView>
</theme>
