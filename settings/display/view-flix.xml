<!--
  MINIMAL FLIX TEST — stripped to bare essentials to find what's broken
-->
<theme>
  <formatVersion>7</formatVersion>

  <customView name="flix" inherits="grid">

    <imagegrid name="gamegrid">
      <pos>0 0.1</pos>
      <size>1 0.85</size>
      <imageSource>thumbnail</imageSource>
      <scrollDirection>horizontal</scrollDirection>
      <autoLayout>5 1</autoLayout>
      <animateSelection>false</animateSelection>
      <autoLayoutSelectedZoom>1.1</autoLayoutSelectedZoom>
      <scrollLoop>true</scrollLoop>
    </imagegrid>

    <gridtile name="default">
      <backgroundColor>FFFFFF20</backgroundColor>
    </gridtile>

    <text name="logoText">
      <pos>0.05 0.03</pos>
      <color>FFFFFF</color>
    </text>

  </customView>
</theme>
