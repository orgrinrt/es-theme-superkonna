<!--
  Theme: Superkonna — Flix view
  Full-screen game art, white gradient bottom, covers floating low.
-->
<theme>
  <formatVersion>7</formatVersion>

  <customView name="flix" inherits="grid">

    <!-- FULL-SCREEN BACKGROUND: selected game's screenshot -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <zIndex>-2</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" begin="0" duration="400" mode="easeOut"/>
      </storyboard>
    </image>

    <video name="md_video">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <zIndex>-1</zIndex>
      <delay>1.5</delay>
      <showSnapshotNoVideo>false</showSnapshotNoVideo>
      <showSnapshotDelay>false</showSnapshotDelay>
      <effect>none</effect>
    </video>

    <!-- White gradient from bottom — covers float in this zone -->
    <image name="flix_gradient" extra="true">
      <path>./assets/fade-ver.png</path>
      <origin>0 1</origin>
      <pos>0 1</pos>
      <size>1 0.55</size>
      <color>FFFFFF</color>
      <rotation>180</rotation>
      <zIndex>1</zIndex>
    </image>

    <!-- === COVER STRIP: Low on screen, in the gradient === -->
    <imagegrid name="gamegrid">
      <pos>0.03 0.72</pos>
      <size>0.94 0.22</size>
      <imageSource>thumbnail</imageSource>
      <scrollDirection>horizontal</scrollDirection>
      <autoLayout>7 1</autoLayout>
      <animateSelection>true</animateSelection>
      <autoLayoutSelectedZoom>1.08</autoLayoutSelectedZoom>
      <padding>0.008 0.012</padding>
      <margin>0.006 0.01</margin>
      <scrollLoop>true</scrollLoop>
      <zIndex>5</zIndex>
      <scrollSound>./assets/sounds/tick.wav</scrollSound>
    </imagegrid>

    <gridtile name="default, selected">
      <selectionMode>image</selectionMode>
      <imageSizeMode>minSize</imageSizeMode>
    </gridtile>

    <gridtile name="default">
      <imageColor>FFFFFFDD</imageColor>
      <backgroundColor>00000000</backgroundColor>
      <backgroundCornerSize>0.008</backgroundCornerSize>
    </gridtile>

    <gridtile name="selected">
      <imageColor>FFFFFFFF</imageColor>
      <backgroundColor>FFFFFF30</backgroundColor>
      <backgroundCornerSize>0.008</backgroundCornerSize>
    </gridtile>

    <image name="gridtile.image">
      <roundCorners>0.008</roundCorners>
    </image>

    <image name="gridtile.image:selected">
      <roundCorners>0.008</roundCorners>
    </image>

    <!-- No text on tiles -->
    <text name="gridtile">
      <visible>false</visible>
    </text>

    <image name="gridtile.marquee">
      <color>00000000</color>
    </image>

    <image name="gridtile.favorite">
      <path>./assets/icons/favorite.png</path>
      <pos>0 0</pos>
      <maxSize>0.2 0.2</maxSize>
      <origin>0 0</origin>
    </image>

    <!-- === SELECTED GAME INFO === -->

    <!-- Game title (prominent, changes with selection) -->
    <text name="md_name">
      <visible>true</visible>
      <pos>0.05 0.55</pos>
      <size>0.6 0.06</size>
      <fontSize>${fontSizeH2-medium}</fontSize>
      <fontPath>${fontDisplay}</fontPath>
      <color>1E2028</color>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" begin="60" duration="200" mode="easeOut"/>
      </storyboard>
    </text>

    <!-- Genre below title -->
    <text name="md_genre">
      <visible>true</visible>
      <pos>0.05 0.63</pos>
      <size>0.4 0.03</size>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <color>1E202899</color>
      <zIndex>6</zIndex>
    </text>

    <!-- Description -->
    <text name="md_description">
      <visible>true</visible>
      <pos>0.05 0.67</pos>
      <size>0.5 0.04</size>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1.3</lineSpacing>
      <color>1E2028B3</color>
      <zIndex>6</zIndex>
    </text>

    <!-- System name (small, above covers) -->
    <text name="logoText">
      <visible>false</visible>
    </text>

    <!-- Hide marquee (causes UNKNOWN text) -->
    <image name="md_marquee">
      <visible>false</visible>
    </image>

    <!-- Hide unused metadata -->
    <text name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount, md_releasedate, md_developer, md_publisher, md_players, md_lastplayed, md_playcount">
      <visible>false</visible>
    </text>

    <datetime name="md_releasedate, md_lastplayed">
      <visible>false</visible>
    </datetime>

    <rating name="md_rating">
      <visible>false</visible>
    </rating>

  </customView>
</theme>
