<!--
  Theme: Superkonna — Flix view
  Full-screen game art background (like system carousel), cover strip floating over it.
  No split screen. No black areas.
-->
<theme>
  <formatVersion>7</formatVersion>

  <customView name="flix" inherits="grid">

    <!-- FULL-SCREEN BACKGROUND: selected game's screenshot -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <zIndex>-2</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" begin="0" duration="400" mode="easeOut"/>
      </storyboard>
    </image>

    <!-- Video replaces screenshot after delay -->
    <video name="md_video">
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1 1</minSize>
      <zIndex>-1</zIndex>
      <delay>1.5</delay>
      <showSnapshotNoVideo>false</showSnapshotNoVideo>
      <showSnapshotDelay>false</showSnapshotDelay>
      <effect>none</effect>
    </video>

    <!-- Bottom gradient: dark fade so covers and text are readable -->
    <image name="flix_gradient" extra="true">
      <path>./assets/fade-ver.png</path>
      <origin>0 1</origin>
      <pos>0 1</pos>
      <size>1 0.6</size>
      <color>0E1117</color>
      <rotation>180</rotation>
      <zIndex>1</zIndex>
    </image>

    <!-- === COVER STRIP: Floating in lower area === -->
    <imagegrid name="gamegrid">
      <pos>0.02 0.58</pos>
      <size>0.96 0.32</size>
      <imageSource>thumbnail</imageSource>
      <scrollDirection>horizontal</scrollDirection>
      <autoLayout>7 1</autoLayout>
      <animateSelection>true</animateSelection>
      <autoLayoutSelectedZoom>1.08</autoLayoutSelectedZoom>
      <padding>0.01 0.02</padding>
      <margin>0.008 0.015</margin>
      <scrollLoop>true</scrollLoop>
      <zIndex>5</zIndex>
      <scrollSound>./assets/sounds/tick.wav</scrollSound>
    </imagegrid>

    <gridtile name="default, selected">
      <selectionMode>image</selectionMode>
      <imageSizeMode>maxSize</imageSizeMode>
    </gridtile>

    <gridtile name="default">
      <imageColor>FFFFFFDD</imageColor>
      <backgroundColor>00000000</backgroundColor>
      <backgroundCornerSize>0.01</backgroundCornerSize>
    </gridtile>

    <gridtile name="selected">
      <imageColor>FFFFFFFF</imageColor>
      <backgroundColor>FFFFFF18</backgroundColor>
      <backgroundCornerSize>0.01</backgroundCornerSize>
    </gridtile>

    <image name="gridtile.image">
      <roundCorners>0.01</roundCorners>
    </image>

    <image name="gridtile.image:selected">
      <roundCorners>0.01</roundCorners>
    </image>

    <!-- No text on tiles — clean cover art only -->
    <text name="gridtile">
      <visible>false</visible>
    </text>

    <image name="gridtile.marquee">
      <color>00000000</color>
    </image>

    <image name="gridtile.favorite">
      <path>./assets/icons/favorite.png</path>
      <pos>0 0</pos>
      <maxSize>0.2 0.2</maxSize>
      <origin>0 0</origin>
    </image>

    <!-- === METADATA: Floating over background, upper-left === -->

    <!-- Game marquee/logo -->
    <image name="md_marquee">
      <pos>0.05 0.08</pos>
      <origin>0 0</origin>
      <maxSize>0.3 0.12</maxSize>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="60" mode="linear"/>
        <animation property="opacity" from="0" to="1" begin="120" duration="200" mode="easeOut"/>
      </storyboard>
    </image>

    <!-- Genre -->
    <text name="md_genre">
      <visible>true</visible>
      <pos>0.05 0.25</pos>
      <size>0.4 0.03</size>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <color>EAEDF3</color>
      <glowColor>000000E6</glowColor>
      <glowSize>3</glowSize>
      <zIndex>6</zIndex>
    </text>

    <!-- Description -->
    <text name="md_description">
      <visible>true</visible>
      <pos>0.05 0.30</pos>
      <size>0.4 0.18</size>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1.4</lineSpacing>
      <color>EAEDF3CC</color>
      <glowColor>000000CC</glowColor>
      <glowSize>2</glowSize>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="60" mode="linear"/>
        <animation property="opacity" from="0" to="0.9" begin="180" duration="220" mode="easeOut"/>
      </storyboard>
    </text>

    <!-- System/collection name -->
    <text name="logoText">
      <origin>0 0.5</origin>
      <pos>0.05 0.53</pos>
      <size>0.4 ${fontSizeH3-medium}</size>
      <fontSize>${fontSizeH3-medium}</fontSize>
      <color>EAEDF3</color>
      <glowColor>000000E6</glowColor>
      <glowSize>3</glowSize>
      <zIndex>6</zIndex>
    </text>

    <!-- Hide everything else -->
    <text name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount, md_releasedate, md_developer, md_publisher, md_players, md_lastplayed, md_playcount, md_name">
      <visible>false</visible>
    </text>

    <datetime name="md_releasedate, md_lastplayed">
      <visible>false</visible>
    </datetime>

    <rating name="md_rating">
      <visible>false</visible>
    </rating>

  </customView>
</theme>
