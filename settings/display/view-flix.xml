<!--
  Theme: Superkonna
  Flix view: Netflix-style horizontal game browser
  Based on Elementerial's elementflix (by mluizvitor, MIT)

  Layout:
    Top 47.5%  — preview area: hero screenshot/video + marquee + metadata
    Bottom 52.5% — horizontal game cover strip with edge fades

  Z-ordering:
    -10  background (solid bgColor, from view-general.xml)
     -1  md_image (hero screenshot of selected game)
      0  md_video (video preview, overlays screenshot)
      2  background_overlay (semi-transparent, dims hero behind grid)
      3  top_vignette (gradient for preview text readability)
      5  gamegrid, md_description, md_genre, rating, logoText
      6  md_marquee, edge fades, badges

  Colors for overlay/fades are set INLINE using theme variables so they
  adapt to the active color scheme without depending on scheme.xml
  customView targeting (which has processing-order issues in ES).
-->

<theme>
  <formatVersion>7</formatVersion>

  <customView name="flix" inherits="grid">

    <!-- === GAME GRID: Horizontal strip in lower half === -->
    <imagegrid name="gamegrid">
      <pos>0 0.475</pos>
      <size>1 0.5</size>
      <size ifHelpPrompts="true">1 0.46</size>
      <imageSource>thumb</imageSource>
      <scrollDirection>horizontal</scrollDirection>
      <animateSelection>false</animateSelection>
      <autoLayoutSelectedZoom>1.075</autoLayoutSelectedZoom>
      <padding>0.065 0.0225</padding>
      <margin>0.016666667 0.025</margin>
      <scrollLoop>true</scrollLoop>
      <zIndex>5</zIndex>
      <scrollSound>./assets/sounds/tick.wav</scrollSound>
    </imagegrid>

    <!-- Tile rendering -->
    <gridtile name="default">
      <imageColor>FFFFFFFF</imageColor>
      <backgroundCornerSize>0.015</backgroundCornerSize>
    </gridtile>

    <gridtile name="default, selected">
      <selectionMode>image</selectionMode>
      <imageSizeMode>maxSize</imageSizeMode>
    </gridtile>

    <gridtile name="selected">
      <backgroundCornerSize>0.015</backgroundCornerSize>
    </gridtile>

    <!-- Rounded corners on cover art -->
    <image name="gridtile.image">
      <roundCorners>0.015</roundCorners>
    </image>

    <image name="gridtile.image:selected">
      <roundCorners>0.015</roundCorners>
    </image>

    <!-- Favorite badge on tiles -->
    <image name="gridtile.favorite">
      <path>./assets/icons/favorite.png</path>
      <pos>0 0</pos>
      <maxSize>0.25 0.25</maxSize>
      <origin>0 0</origin>
    </image>

    <!-- Tile label: game name below cover art -->
    <text name="gridtile">
      <size>1 0.2</size>
      <pos>0 0.78</pos>
      <fontPath>${fontBody}</fontPath>
      <fontSize>${fontSizeCaption-medium}</fontSize>
      <alignment>center</alignment>
      <lineSpacing>1.2</lineSpacing>
    </text>

    <!-- Hide tile marquee (full marquee shown in preview area) -->
    <image name="gridtile.marquee">
      <color>00000000</color>
    </image>

    <!-- === EDGE FADES: Soft left/right bleed on game strip === -->
    <!-- Colors set INLINE so they work regardless of scheme.xml targeting -->
    <image name="verticalFadeLeft,verticalFadeRight" extra="true">
      <origin>0.5 0.5</origin>
      <size>0.075 0.525</size>
      <color>${bgColor}</color>
      <path>./assets/fade-hor.png</path>
      <zIndex>6</zIndex>
    </image>

    <image name="verticalFadeLeft" extra="true">
      <pos>0.0375 0.7375</pos>
    </image>

    <image name="verticalFadeRight" extra="true">
      <pos>0.9625 0.7375</pos>
      <rotation>180</rotation>
    </image>

    <!-- === PREVIEW AREA: Top half === -->

    <!-- Selected game marquee/logo (upper-left area) -->
    <image name="md_marquee">
      <pos>0.233333333 0.125</pos>
      <origin>0.5 0.5</origin>
      <maxSize>0.4 0.225</maxSize>
      <zIndex>6</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="60" mode="linear"/>
        <animation property="opacity" from="0" to="1" begin="120" duration="200" mode="easeOut"/>
        <animation property="scale" from="0.95" to="1" begin="120" duration="250" mode="Bump"/>
      </storyboard>
    </image>

    <!-- Background screenshot of selected game (right side, full-bleed) -->
    <image name="md_image">
      <origin>0.5 0.5</origin>
      <pos>0.7 0.25</pos>
      <minSize>0.7 0.55</minSize>
      <zIndex>-1</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="1" begin="0" duration="400" mode="easeOut"/>
      </storyboard>
    </image>

    <!-- Video preview: plays after 1s delay over screenshot -->
    <video name="md_video">
      <origin>0.5 0.5</origin>
      <pos>0.7 0.25</pos>
      <minSize>0.6 0.5</minSize>
      <zIndex>0</zIndex>
      <delay>1</delay>
      <showSnapshotNoVideo>false</showSnapshotNoVideo>
      <showSnapshotDelay>false</showSnapshotDelay>
      <effect>none</effect>
    </video>

    <!-- Game description -->
    <text name="md_description">
      <visible>true</visible>
      <pos>0.033333333 0.25</pos>
      <size>0.433333333 0.15</size>
      <fontPath>${fontLight}</fontPath>
      <lineSpacing>1.3</lineSpacing>
      <zIndex>5</zIndex>
      <storyboard>
        <animation property="opacity" from="0" to="0" duration="60" mode="linear"/>
        <animation property="opacity" from="0" to="0.85" begin="180" duration="220" mode="easeOut"/>
      </storyboard>
    </text>

    <!-- Semi-transparent overlay between bg art and grid
         Color set INLINE — this is the key fix vs relying on scheme.xml -->
    <image name="background_overlay" extra="true">
      <size>1 1</size>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <color>${bgColor}${percent.50}</color>
      <zIndex>2</zIndex>
    </image>

    <!-- Top vignette: gradient for preview area text readability -->
    <image name="top_vignette" extra="true">
      <path>./assets/fade-ver.png</path>
      <size>1 0.25</size>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <color>${bgColor}${percent.70}</color>
      <zIndex>3</zIndex>
    </image>

    <!-- Hide metadata labels (values shown selectively below) -->
    <text name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount, md_releasedate, md_developer, md_publisher, md_players, md_lastplayed, md_playcount, md_name">
      <visible>false</visible>
    </text>

    <datetime name="md_releasedate, md_lastplayed">
      <visible>false</visible>
    </datetime>

    <!-- Rating: hide in flix (too noisy with the preview area) -->
    <rating name="md_rating">
      <visible>false</visible>
    </rating>

    <!-- System name: above game strip -->
    <text name="logoText">
      <origin>0 0.5</origin>
      <pos>0.033333333 0.45</pos>
    </text>

  </customView>
</theme>
