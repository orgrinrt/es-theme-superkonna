<!--
  Theme: Superkonna
  Aspect ratio: 4:3 overrides
-->

<theme>
  <formatVersion>7</formatVersion>

  <variables>
    <cardCornerRadius>12</cardCornerRadius>
    <carouselWidth>1.40</carouselWidth>
    <carouselXOffset>-0.20</carouselXOffset>
    <carouselH>0.25</carouselH>
    <cardMaxVisible>5</cardMaxVisible>
  </variables>

  <!-- Top bar: slightly taller for 4:3 -->
  <view name="screen">
    <image name="topbar_bg" extra="true">
      <size>1 0.07</size>
    </image>
  </view>
</theme>
