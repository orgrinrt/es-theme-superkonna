<!--
  Theme: Superkonna
  Font size: medium (default — variables.xml has these values already)
-->

<theme>
  <formatVersion>7</formatVersion>
  <!-- Medium is the default in variables.xml. Nothing to override. -->

  <!-- Menu text sizes -->
  <view name="menu">
    <menuText name="menutext">
      <fontSize>${fontSizeBody}</fontSize>
    </menuText>
    <menuTextSmall name="menutextsmall">
      <fontSize>${fontSizeCaption}</fontSize>
    </menuTextSmall>
    <menuGroup name="menugroup">
      <fontSize>${fontSizeCaption}</fontSize>
    </menuGroup>
    <menuText name="menutitle">
      <fontSize>${fontSizeH2}</fontSize>
    </menuText>
    <menuText name="menufooter">
      <fontSize>${fontSizeCaption}</fontSize>
    </menuText>
  </view>
</theme>
