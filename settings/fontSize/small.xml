<!--
  Theme: Superkonna
  Font size: small — overrides base font size variables
-->

<theme>
  <formatVersion>7</formatVersion>

  <variables>
    <fontSizeH1>0.054</fontSizeH1>
    <fontSizeH2>0.041</fontSizeH2>
    <fontSizeH3>0.033</fontSizeH3>
    <fontSizeBody>0.028</fontSizeBody>
    <fontSizeCaption>0.023</fontSizeCaption>
  </variables>

  <view name="menu">
    <menuText name="menutext"><fontSize>${fontSizeBody}</fontSize></menuText>
    <menuTextSmall name="menutextsmall"><fontSize>${fontSizeCaption}</fontSize></menuTextSmall>
    <menuGroup name="menugroup"><fontSize>${fontSizeCaption}</fontSize></menuGroup>
    <menuText name="menutitle"><fontSize>${fontSizeH2}</fontSize></menuText>
    <menuText name="menufooter"><fontSize>${fontSizeCaption}</fontSize></menuText>
  </view>
</theme>
