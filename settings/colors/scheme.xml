<!--
  Theme: Superkonna
  Color scheme application: wires semantic color vars into ES elements.
  No carousel colors here — those come from per-system metadata + itemTemplate.
-->

<theme>
  <formatVersion>7</formatVersion>

  <!-- ── Global defaults ─────────────────────────────────────── -->

  <view name="system">
    <image name="background">
      <color>${bgColor}</color>
    </image>
  </view>

  <!-- ── Screen chrome ───────────────────────────────────────── -->

  <view name="screen">
    <text name="clock">
      <color>${fgColor}</color>
      <glowColor>${shadowColor}${percent.60}</glowColor>
      <glowSize>2</glowSize>
    </text>

    <batteryIndicator name="batteryIndicator">
      <color>${fgColor}</color>
    </batteryIndicator>

    <controllerActivity name="controllerActivity">
      <color>${subtleColor}${percent.30}</color>
      <activityColor>${mainColor}${percent.70}</activityColor>
      <hotkeyColor>${mainColor}</hotkeyColor>
    </controllerActivity>

    <image name="topbar_bg" extra="true">
      <color>${cardColor}${percent.70}</color>
    </image>

    <!-- Built-in helpsystem hidden — custom hint strips used instead -->
    <helpsystem name="help">
      <textColor>00000000</textColor>
      <iconColor>00000000</iconColor>
    </helpsystem>
  </view>

  <!-- ── Menu colors ─────────────────────────────────────────── -->

  <view name="menu">
    <menuText name="menutext">
      <selectedColor>${onMainColor}</selectedColor>
      <selectorColor>${mainColor}</selectorColor>
      <color>${fgColor}</color>
      <separatorColor>${subtleColor}${percent.10}</separatorColor>
    </menuText>

    <menuTextSmall name="menutextsmall">
      <color>${subtleColor}${percent.50}</color>
    </menuTextSmall>

    <menuGroup name="menugroup">
      <color>${fgColor}${percent.80}</color>
      <separatorColor>${sectColor}${percent.40}</separatorColor>
      <backgroundColor>${cardColor}${percent.60}</backgroundColor>
    </menuGroup>

    <menuBackground name="menubg">
      <color>${cardColor}${percent.90}</color>
    </menuBackground>

    <menuText name="menufooter">
      <color>${subtleColor}${percent.40}</color>
    </menuText>

    <menuText name="menutitle">
      <color>${fgColor}</color>
    </menuText>

    <menuSwitch name="menuswitch">
      <color>${mainColor}</color>
      <colorOff>${subtleColor}${percent.30}</colorOff>
    </menuSwitch>

    <menuButton name="menubutton">
      <color>${mainColor}</color>
      <textColor>${onMainColor}</textColor>
    </menuButton>

    <menuTextEdit name="menutextedit">
      <color>${fgColor}</color>
    </menuTextEdit>

    <menuIcons name="menuicons">
      <color>${subtleColor}${percent.60}</color>
    </menuIcons>
  </view>

  <!-- ── Splash screen ───────────────────────────────────────── -->

  <view name="splash">
    <image name="progressbar">
      <color>${mainColor}</color>
    </image>
  </view>

</theme>
