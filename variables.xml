<!--
  Theme: Superkonna
  Global variables: single source of truth for all sizing, timing, fonts, opacity
-->

<theme>
  <formatVersion>7</formatVersion>

  <variables>
    <!-- ── Fonts ─────────────────────────────────────────────── -->
    <fontDisplay>./assets/fonts/Inter/Inter-Bold.otf</fontDisplay>
    <fontBody>./assets/fonts/Inter/Inter-Regular.otf</fontBody>
    <fontLight>./assets/fonts/Inter/Inter-Light.otf</fontLight>

    <!-- ── Font size tiers (medium = default) ────────────────── -->
    <fontSizeH1>0.06</fontSizeH1>
    <fontSizeH2>0.046</fontSizeH2>
    <fontSizeH3>0.037</fontSizeH3>
    <fontSizeBody>0.032</fontSizeBody>
    <fontSizeCaption>0.025</fontSizeCaption>

    <!-- ── Carousel geometry ─────────────────────────────────── -->
    <carouselWidth>2.5</carouselWidth>
    <carouselXOffset>-0.85</carouselXOffset>
    <carouselY>0.68</carouselY>
    <carouselH>0.30</carouselH>
    <cardLogoSize>0.18 0.22</cardLogoSize>
    <cardLogoScale>1.25</cardLogoScale>
    <cardMaxVisible>11</cardMaxVisible>

    <!-- ── Card styling ──────────────────────────────────────── -->
    <cardCornerRadius>16</cardCornerRadius>
    <cardCornerRadiusScaled>18</cardCornerRadiusScaled>
    <cardArtSize>0.92 0.92</cardArtSize>
    <cardLogoMaxSize>0.85 0.3</cardLogoMaxSize>
    <cardLogoY>0.5</cardLogoY>

    <!-- ── Animation timing (ms) ─────────────────────────────── -->
    <animFast>150</animFast>
    <animMedium>250</animMedium>
    <animSlow>400</animSlow>
    <animCrossfade>1000</animCrossfade>

    <!-- ── Opacity levels ────────────────────────────────────── -->
    <artOverlayOpacity>0.15</artOverlayOpacity>
    <gradientOverlayOpacity>0.25</gradientOverlayOpacity>
    <glintPeakOpacity>0.25</glintPeakOpacity>
    <bgOverlayOpacity>0.50</bgOverlayOpacity>
    <vignetteOpacity>0.90</vignetteOpacity>
    <minCardOpacity>0.5</minCardOpacity>

    <!-- ── Scale ─────────────────────────────────────────────── -->
    <cardActivateScale>1.08</cardActivateScale>

    <!-- ── Hex opacity suffixes ──────────────────────────────── -->
    <percent.90>E6</percent.90>
    <percent.80>CC</percent.80>
    <percent.70>B3</percent.70>
    <percent.60>99</percent.60>
    <percent.50>80</percent.50>
    <percent.40>66</percent.40>
    <percent.30>4D</percent.30>
    <percent.20>33</percent.20>
    <percent.10>1A</percent.10>
    <percent.5>0D</percent.5>
  </variables>
</theme>
