<!--
  Theme: Superkonna
  Splash screen: minimal, unbranded, clean
-->

<theme>
  <formatVersion>7</formatVersion>

  <view name="splash">
    <splash name="splash">
      <backgroundColor>0E1117</backgroundColor>
    </splash>

    <!-- Progress bar: thin accent line at bottom -->
    <image name="progressbar">
      <color>0E1117</color>
      <origin>0.5 1</origin>
      <pos>0.5 0.98</pos>
      <maxSize>0.4 0.003</maxSize>
      <minSize>0.4 0.003</minSize>
      <roundCorners>0.002</roundCorners>
    </image>

    <image name="progressbar:active">
      <color>D64060</color>
      <tile>true</tile>
    </image>

    <!-- Loading text: minimal -->
    <text name="label">
      <alignment>center</alignment>
      <fontPath>${fontLight}</fontPath>
      <fontSize>0.022</fontSize>
      <color>EAEDF340</color>
      <origin>0.5 1</origin>
      <pos>0.5 0.965</pos>
    </text>
  </view>
</theme>
