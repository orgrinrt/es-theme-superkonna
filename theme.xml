<!--
  Theme: Superkonna
  An asset-agnostic ES theme for Batocera.
  Forked from Elementerial by mluizvitor (MIT License).
  See DESIGN.md for architecture and design decisions.
-->

<theme>
  <formatVersion>7</formatVersion>

  <!-- Shared variables (single source of truth) -->
  <include>./variables.xml</include>

  <!-- Per-system metadata (card colors) -->
  <include>./_inc/metadata/${system.theme}.xml</include>

  <!-- Color scheme selection -->
  <subset name="Color scheme" displayName="Color scheme">
    <include name="light" displayName="Light (default)">./settings/colors/light/main.xml</include>
    <include name="dark" displayName="Dark">./settings/colors/dark/main.xml</include>
  </subset>

  <!-- Font size selection -->
  <subset name="FontSize" displayName="Font Size">
    <include name="medium">./settings/fontSize/medium.xml</include>
    <include name="small">./settings/fontSize/small.xml</include>
    <include name="large">./settings/fontSize/large.xml</include>
  </subset>

  <!-- Aspect ratio -->
  <subset name="Aspect Ratio" displayName="Aspect Ratio">
    <include name="16-9" displayName="16:9 (default)">./settings/aspect/16-9.xml</include>
    <include name="4-3" displayName="4:3">./settings/aspect/4-3.xml</include>
  </subset>

  <!-- Apply color scheme to elements -->
  <include>./settings/colors/scheme.xml</include>

  <!-- View definitions -->
  <include>./settings/display/view-system.xml</include>
  <include>./settings/display/view-grid.xml</include>
  <include>./settings/display/view-flix.xml</include>

</theme>
